# ============================================================
# AEGIS — Environment Variables
# Copy this file to .env and fill in real values
# Never commit .env to version control
# ============================================================

# --- Database ---
POSTGRES_USER=aegis
POSTGRES_PASSWORD=aegis_dev_password
POSTGRES_DB=aegis_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://aegis:aegis_dev_password@postgres:5432/aegis_db

# --- Backend ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
SECRET_KEY=CHANGE_ME_super_secret_key_at_least_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- GitHub OAuth ---
GITHUB_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret
GITHUB_REDIRECT_URI=http://localhost:3000/auth/callback

# --- GitHub API ---
# Personal access token for GitHub API (used in development)
GITHUB_TOKEN=your_github_personal_access_token

# --- Anthropic (for Themis & Dike agents) ---
ANTHROPIC_API_KEY=your_anthropic_api_key

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Solana (Phase 11) ---
SOLANA_NETWORK=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
# SOLANA_WALLET_PRIVATE_KEY=  # Set in Phase 11

# --- Environment ---
ENVIRONMENT=development
LOG_LEVEL=INFO
